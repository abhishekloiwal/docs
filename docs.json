{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Atlas Docs",
  "description": "Use hosted Atlas with your own agents, skills, and customer-owned gateway.",
  "logo": {
    "light": "/atlas-docs-wordmark.svg",
    "dark": "/atlas-docs-wordmark.svg"
  },
  "favicon": "/apple-touch-icon.svg",
  "seo": {
    "metatags": {
      "canonical": "https://docs.atlasmeets.com"
    }
  },
  "colors": {
    "primary": "#0E7A55",
    "light": "#E9F7F1",
    "dark": "#0B1F18"
  },
  "background": {
    "color": {
      "light": "#F5F5F0",
      "dark": "#0B1F18"
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Hosted Atlas",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "atlas/dashboard-setup",
              "atlas/agents-and-skills",
              "atlas/deployment-modes"
            ]
          }
        ]
      },
      {
        "tab": "Gateway",
        "groups": [
          {
            "group": "Build And Connect",
            "pages": [
              "gateway/overview",
              "gateway/build-with-an-agent",
              "gateway/mock-gateway"
            ]
          },
          {
            "group": "Contract v1",
            "pages": [
              "gateway/manifest",
              "gateway/invoke",
              "gateway/jobs-and-approvals",
              "gateway/auth-and-signing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Gateway API",
            "openapi": "openapi/gateway-v1.yaml",
            "pages": [
              "reference/gateway-reference",
              "GET /v1/manifest",
              "POST /v1/invoke",
              "GET /v1/jobs/{jobId}",
              "POST /v1/jobs/{jobId}/cancel"
            ]
          }
        ]
      }
    ]
  }
}
